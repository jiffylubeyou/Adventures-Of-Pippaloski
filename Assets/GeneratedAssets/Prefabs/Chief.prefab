  - playerPrompt: Gimmie yoour boat
    npcResponse: No. First you must complete the quest I have commissioned you
    closesDialogue: 0
    oneTimeOnly: 0
    startsLocked: 1
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags: []
    clearsFlags: []
    setsFlags: []
    grantsBoatAccess: 0
    opensShop: 0
    followUpLines: []
  - playerPrompt: I would like to embark on a quest
    npcResponse: Alright, you must find a powerful and ancient bone that is lost
      to me
    closesDialogue: 0
    oneTimeOnly: 0
    startsLocked: 0
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags: []
    clearsFlags: []
    setsFlags: []
    grantsBoatAccess: 0
    opensShop: 0
    followUpLines:
    - playerPrompt: Alright, I'll do it
      npcResponse: Good... Good... Bring me a white bone that is lost to me
      closesDialogue: 1
      oneTimeOnly: 1
      startsLocked: 0
      unlocksLineIndices: 010000000300000004000000
      locksLineIndices: 0000000002000000
      requiredFlags: []
      forbiddenFlags: []
      clearsFlags: []
      setsFlags: []
      grantsBoatAccess: 0
      opensShop: 0
      followUpLines: []
    - playerPrompt: Take a hike Chief
      npcResponse: Your loss
      closesDialogue: 1
      oneTimeOnly: 0
      startsLocked: 0
      unlocksLineIndices: 
      locksLineIndices: 
      requiredFlags: []
      forbiddenFlags: []
      clearsFlags: []
      setsFlags: []
      grantsBoatAccess: 0
      opensShop: 0
      followUpLines: []
  - playerPrompt: I have your bone
    npcResponse: No you don't you little liar
    closesDialogue: 1
    oneTimeOnly: 0
    startsLocked: 1
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags:
    - has_bone
    clearsFlags: []
    setsFlags: []
    grantsBoatAccess: 0
    opensShop: 0
    followUpLines: []
  - playerPrompt: I have your bone
    npcResponse: You have found it, I am bound by my word. My boat is yours. It should
      be docked outside for you
    closesDialogue: 1
    oneTimeOnly: 1
    startsLocked: 1
    unlocksLineIndices: 05000000
    locksLineIndices: 030000000200000001000000
