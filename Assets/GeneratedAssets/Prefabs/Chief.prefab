  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  talkRadius: 15
  npcName: Chief
  greeting: It is I, the great Chief dog Pooch
  lines:
  - playerPrompt: Give me your boat, I want it
    npcResponse: No. First you must embark on a quest
    closesDialogue: 0
    oneTimeOnly: 0
    startsLocked: 0
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags: []
