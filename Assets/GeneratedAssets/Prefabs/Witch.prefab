MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5436354476281076278}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 50f25e35a6830fb4e999172639516f16, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  talkRadius: 10
  npcName: Witch
  greeting: Why hello little child
  lines:
  - playerPrompt: I'm a dog
    npcResponse: Oh yes yes, I'm practically blind these days. Too many risky potions
      in my history
    closesDialogue: 0
    oneTimeOnly: 0
    startsLocked: 0
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags: []
    clearsFlags: []
    setsFlags: []
    grantsBoatAccess: 0
    opensShop: 0
    startsWitchLunchQuest: 0
    followUpLines: []
  - playerPrompt: I need money
    npcResponse: I can get some for you. Will you run to burger king and pick someting
      up for me?
    closesDialogue: 0
    oneTimeOnly: 0
    startsLocked: 0
    unlocksLineIndices: 
    locksLineIndices: 
    requiredFlags: []
    forbiddenFlags: []
    clearsFlags: []
    setsFlags: []
    grantsBoatAccess: 0
    opensShop: 0
    startsWitchLunchQuest: 0
    followUpLines:
    - playerPrompt: Alright, I'll head out
      npcResponse: Perfect! The Burgur King is above us, pick up the burger inside.
        Be quick my child, the faster you retrive my lunch, the more coins you'll
        recieve!
      closesDialogue: 1
      oneTimeOnly: 0
      startsLocked: 0
      unlocksLineIndices: 02000000
